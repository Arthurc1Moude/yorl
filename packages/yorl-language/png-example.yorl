^yorl 1.0.0-2437\

class -className=class(*1) -type=board -@set.{board}.color=#FFFFFF;
  .text
    .text.config -size=50 -(txt='hello, world!');
  .icon
    .icon.config -size=50 -(ico='@url{https://icon.example.com/141703075687abb}');
  .png
    .png.config -size=50 -(png='@path{/home/aimoude149/example.png}');
export class.{class(*1)} -as[paf:imageType.png] -to(dir='@path{/home/aimoude149/amari/image/png}');

^END_OF_YORL @type=config.none
