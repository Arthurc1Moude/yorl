{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Yorl",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#colors"
    },
    {
      "include": "#special-syntax"
    },
    {
      "include": "#properties"
    },
    {
      "include": "#identifiers"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.exclamation.yorl",
          "match": "!.*$",
          "captures": {
            "0": {
              "name": "comment.line.yorl"
            }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.yorl",
          "match": "\\b(class|import|function|export)\\b"
        },
        {
          "name": "keyword.other.header.yorl",
          "match": "\\^(yorl|END_OF_YORL|yorl-builtin|END_OF_BUILTIN)"
        },
        {
          "name": "keyword.other.version.yorl",
          "match": "\\b[0-9]+\\.[0-9]+\\.[0-9]+-[0-9]+\\b"
        },
        {
          "name": "keyword.other.type.yorl",
          "match": "\\b(application|board|whiteboard|config|data|image|ai|neural)\\b"
        },
        {
          "name": "keyword.operator.import.yorl",
          "match": "-as\\[|\\]"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.single.yorl",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.exception.yorl",
              "match": "/em\\+[0-9]+"
            },
            {
              "name": "constant.character.escape.yorl",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.double.yorl",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.exception.yorl",
              "match": "/em\\+[0-9]+"
            },
            {
              "name": "constant.character.escape.yorl",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.unquoted.paren.yorl",
          "match": "\\(txt='[^']*'\\)|\\(txt=\"[^\"]*\"\\)|\\(img='[^']*'\\)|\\(img=\"[^\"]*\"\\)|\\(src='[^']*'\\)|\\(src=\"[^\"]*\"\\)"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.yorl",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.yorl",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "colors": {
      "patterns": [
        {
          "name": "constant.other.color.hex.yorl",
          "match": "#[0-9a-fA-F]{6}\\b"
        },
        {
          "name": "constant.other.color.hex.yorl",
          "match": "#[0-9a-fA-F]{3}\\b"
        }
      ]
    },
    "special-syntax": {
      "patterns": [
        {
          "name": "support.function.url.yorl",
          "match": "@url\\{[^}]*\\}"
        },
        {
          "name": "support.function.path.yorl",
          "match": "@path\\{[^}]*\\}"
        },
        {
          "name": "support.function.dep.yorl",
          "match": "@dep\\{[^}]*\\}"
        },
        {
          "name": "support.function.set.yorl",
          "match": "@set\\.[a-zA-Z0-9_.{}]*"
        },
        {
          "name": "support.function.call.yorl",
          "match": "@call\\.[a-zA-Z0-9_.{}]*"
        },
        {
          "name": "support.type.object.yorl",
          "begin": "\\{",
          "end": "\\}",
          "patterns": [
            {
              "include": "#strings"
            },
            {
              "include": "#numbers"
            },
            {
              "include": "#colors"
            },
            {
              "name": "variable.other.property.yorl",
              "match": "[a-zA-Z_][a-zA-Z0-9_]*(?=:)"
            },
            {
              "name": "punctuation.separator.yorl",
              "match": "[,:]"
            }
          ]
        }
      ]
    },
    "properties": {
      "patterns": [
        {
          "name": "variable.parameter.property.yorl",
          "match": "-[a-zA-Z][a-zA-Z0-9_]*(?==)"
        },
        {
          "name": "variable.parameter.flag.yorl",
          "match": "-[a-zA-Z][a-zA-Z0-9_.-]*"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "entity.name.class.config.yorl",
          "match": "\\.[a-zA-Z][a-zA-Z0-9_]*(?=\\s|$)"
        },
        {
          "name": "entity.name.class.nested.yorl",
          "match": "\\.[a-zA-Z][a-zA-Z0-9_]*\\.[a-zA-Z][a-zA-Z0-9_]*"
        },
        {
          "name": "entity.name.type.builtin.yorl",
          "match": "\\b(SIZE|COLOR|POSITION|FORMAT|QUALITY|FILTER|DTYPE|ENCODING|MODEL|ACTIVATION|OPTIMIZER|LOSS)\\.[A-Z_]+\\b"
        },
        {
          "name": "entity.name.type.canvas.yorl",
          "match": "\\b(canvas|header|content|footer|config|style|text|shape|drawing|transform)\\b"
        },
        {
          "name": "variable.other.constant.yorl",
          "match": "\\b(width|height|size|position|color|background|font|family|weight|bold|italic|type|rectangle|circle|line|x|y|scale|rotate|align|horizontal|vertical|center|middle|top|bottom|left|right)\\b"
        },
        {
          "name": "variable.other.yorl",
          "match": "\\b[a-zA-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.yorl",
          "match": "="
        },
        {
          "name": "punctuation.terminator.yorl",
          "match": ";"
        },
        {
          "name": "punctuation.separator.yorl",
          "match": "[,:]"
        },
        {
          "name": "punctuation.definition.yorl",
          "match": "\\\\"
        }
      ]
    }
  },
  "scopeName": "source.yorl"
}
