{
  "name": "yorl-language",
  "displayName": "Yorl Programming Language",
  "description": "Syntax highlighting and language support for Yorl programming language",
  "version": "1.0.2",
  "publisher": "MoudeAI",
  "author": "Arthurc1Moude",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Arthurc1Moude/yorl.git",
    "directory": "packages/yorl-language"
  },
  "bugs": {
    "url": "https://github.com/Arthurc1Moude/yorl/issues"
  },
  "homepage": "https://github.com/Arthurc1Moude/yorl#readme",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "yorl",
    "syntax",
    "highlighting",
    "language",
    "grammar"
  ],
  "contributes": {
    "languages": [
      {
        "id": "yorl",
        "aliases": ["Yorl", "yorl"],
        "extensions": [".yorl", ".yol", ".ybuiltin"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "yorl",
        "scopeName": "source.yorl",
        "path": "./yorl.tmLanguage.json"
      }
    ]
  }
}
