{
  "name": "yorl-language",
  "displayName": "Yorl",
  "description": "Syntax highlighting and language support for Yorl programming language with GUI whiteboard support",
  "version": "1.4.1",
  "publisher": "MoudeAI",
  "author": "Arthurc1Moude",
  "license": "SEE LICENSE IN LICENSE",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Arthurc1Moude/yorl.git",
    "directory": "packages/yorl-language"
  },
  "bugs": {
    "url": "https://github.com/Arthurc1Moude/yorl/issues"
  },
  "homepage": "https://github.com/Arthurc1Moude/yorl#readme",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "main": "./extension.js",
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "yorl",
    "syntax",
    "highlighting",
    "language",
    "grammar"
  ],
  "contributes": {
    "commands": [
      {
        "command": "yorl.compile",
        "title": "Yorl: Compile Current File"
      }
    ],
    "languages": [
      {
        "id": "yorl",
        "aliases": ["Yorl", "yorl"],
        "extensions": [".yorl", ".yol", ".ybuiltin"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./file-icon-ofm.png",
          "dark": "./file-icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "yorl",
        "scopeName": "source.yorl",
        "path": "./yorl.tmLanguage.json"
      }
    ],
    "icons": {
      "yorl-icon": {
        "description": "Yorl file icon",
        "default": {
          "fontPath": "./file-icon.png",
          "fontCharacter": "Y"
        }
      }
    }
  }
}
