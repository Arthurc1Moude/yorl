{
  "comments": {
    "lineComment": "!"
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "'", "close": "'", "notIn": ["string", "comment"] },
    { "open": "\"", "close": "\"", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["'", "'"],
    ["\"", "\""]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*class|^\\s*function",
      "end": "^\\s*export|^END_OF_YORL"
    }
  },
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(class|function).*$",
    "decreaseIndentPattern": "^\\s*(export|^END_OF_YORL).*$"
  }
}
